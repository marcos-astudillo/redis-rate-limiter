# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT
# Copy this file to .env and fill in values for local use.
# ─────────────────────────────────────────────────────────────────────────────

# Application
NODE_ENV=development
PORT=3000

# ── Redis (local) ─────────────────────────────────────────────────────────────
# Use individual vars for local dev (docker compose up redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# ── PostgreSQL (local) ────────────────────────────────────────────────────────
# Use individual vars for local dev (docker compose up postgres)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rate_limiter
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# ─────────────────────────────────────────────────────────────────────────────
# RAILWAY DEPLOYMENT
# Railway injects these automatically when you add a Postgres / Redis plugin.
# You do NOT need to set them manually — Railway sets them for you.
# Leave them commented out for local dev.
# ─────────────────────────────────────────────────────────────────────────────

# DATABASE_URL=postgresql://user:password@host:port/database
# REDIS_URL=redis://:password@host:port

# ─────────────────────────────────────────────────────────────────────────────
# RATE LIMITER
# ─────────────────────────────────────────────────────────────────────────────

# Default limits — used by rateLimiter() middleware when no plan is specified
RATE_LIMIT_CAPACITY=100
RATE_LIMIT_REFILL_PER_SEC=10
RATE_LIMIT_WINDOW_SEC=60

# "open"   = allow requests when Redis is unavailable (higher availability)
# "closed" = deny requests when Redis is unavailable (safer for backends)
RATE_LIMIT_FAIL_POLICY=open

# Global on/off switch — false bypasses all rate limiting
RATE_LIMIT_ENABLED=true

# In-memory fast-path: skip Redis for keys clearly under their limit
RATE_LIMIT_LOCAL_CACHE_ENABLED=false
RATE_LIMIT_LOCAL_CACHE_TTL_MS=500

# ─────────────────────────────────────────────────────────────────────────────
# LOGGING & DOCS
# ─────────────────────────────────────────────────────────────────────────────

LOG_LEVEL=info

# Swagger UI:    http://localhost:3000/api-docs
# OpenAPI JSON:  http://localhost:3000/api-docs.json
