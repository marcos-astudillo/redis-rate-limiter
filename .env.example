# Application
NODE_ENV=development
PORT=3000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# Rate Limiter defaults (can be overridden per route/plan)
RATE_LIMIT_CAPACITY=100
RATE_LIMIT_REFILL_PER_SEC=10
RATE_LIMIT_WINDOW_SEC=60

# Fail policy: "open" (allow when Redis is down) | "closed" (deny when Redis is down)
RATE_LIMIT_FAIL_POLICY=open

# Feature flags
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOCAL_CACHE_ENABLED=false
RATE_LIMIT_LOCAL_CACHE_TTL_MS=500

# Logging
LOG_LEVEL=info
